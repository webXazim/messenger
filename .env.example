# =========================================================
# Messenger Backend Configuration
# Copy this file to `.env` and fill in the values you own.
# Keep your real secrets only in `.env`, never in git.
# =========================================================

# ---------------------------------------------------------
# 1. Values you should set for live development
# ---------------------------------------------------------
SECRET_KEY=replace-with-a-long-random-secret-key
APP_DOMAIN=localhost
DB_PASSWORD=replace-with-your-postgres-password
DEFAULT_FROM_EMAIL=no-reply@example.com
FRONTEND_BASE_URL=https://dm.crescentsphere.com
SITE_URL=https://dm.crescentsphere.com
NGINX_CONF_PATH=./nginx/snm.conf

# Optional but usually required in real deployments:
EMAIL_HOST=smtp.example.com
EMAIL_HOST_USER=smtp-user
EMAIL_HOST_PASSWORD=smtp-password
GOOGLE_OIDC_CLIENT_ID=
APPLE_OIDC_CLIENT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=

# ---------------------------------------------------------
# 2. Core application
# ---------------------------------------------------------
DEBUG=True
MESSENGER_ENVIRONMENT=development
MESSENGER_REQUIRE_SECURE_SETTINGS=False
APP_VERSION=v24-dev
SERVICE_NAME=messenger_api
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,web,nginx,dm.crescentsphere.com

# ---------------------------------------------------------
# 2b. Central auth/payment/admin control
# ---------------------------------------------------------
CENTRAL_PROJECT_CODE=messenger
CENTRAL_BUSINESS_PRODUCT_CODE=chat
CENTRAL_AUTH_ENABLED=True
CENTRAL_PAYMENTS_ENABLED=True
CENTRAL_ACCESS_MODE=observe
CENTRAL_ADMIN_ENABLED=True
AUTH_PAYMENT_BASE_URL=https://accounts.crescentsphere.com
CENTRAL_AUTH_PUBLIC_BASE_URL=https://accounts.crescentsphere.com
ADMIN_CONTROL_BASE_URL=https://a2.crescentsphere.com
CENTRAL_ADMIN_PUBLIC_BASE_URL=https://a2.crescentsphere.com
CENTRAL_AUTH_CALLBACK_PATH=/auth/callback/
CENTRAL_AUTH_CALLBACK_URL=https://dm.crescentsphere.com/auth/callback/
CENTRAL_LOGIN_URL=https://accounts.crescentsphere.com/login/?next=https%3A%2F%2Fdm.crescentsphere.com%2Fauth%2Fcallback%2F
CENTRAL_SIGNUP_URL=https://accounts.crescentsphere.com/signup/?next=https%3A%2F%2Fdm.crescentsphere.com%2Fauth%2Fcallback%2F
CENTRAL_ACCOUNT_URL=https://accounts.crescentsphere.com/account/
CENTRAL_PASSWORD_RESET_URL=https://accounts.crescentsphere.com/forgot-password/
CENTRAL_EMAIL_VERIFICATION_URL=https://accounts.crescentsphere.com/verify-email/
CENTRAL_LOGOUT_URL=https://accounts.crescentsphere.com/logout/?next=https%3A%2F%2Fdm.crescentsphere.com%2F
AUTH_PAYMENT_ADMIN_SERVICE_KEY=adm_dev_shared_admin_service_key_change_me
AUTH_PAYMENT_ADMIN_SIGNING_SECRET=ask_dev_shared_admin_signing_secret_change_me
AUTH_PAYMENT_JWT_ALGORITHM=RS256
AUTH_PAYMENT_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nreplace-me\n-----END PUBLIC KEY-----"
AUTH_PAYMENT_JWT_SIGNING_KEY=
AUTH_PAYMENT_JWT_ISSUER=https://accounts.crescentsphere.com
AUTH_PAYMENT_JWT_AUDIENCE=messenger-api
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTH_PAYMENT_REQUEST_TIMEOUT_SECONDS=10

# ---------------------------------------------------------
# 3. Frontend / browser origins
# ---------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://dm.crescentsphere.com,https://accounts.crescentsphere.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,https://dm.crescentsphere.com

# ---------------------------------------------------------
# 4. Database
# ---------------------------------------------------------
DB_ENGINE=postgres
DB_NAME=messenger_api
DB_USER=postgres
DB_PASSWORD=replace-with-your-postgres-password
DB_HOST=postgres
DB_PORT=5432
DATABASE_CONN_MAX_AGE=60
DATABASE_CONN_HEALTH_CHECKS=True

# For local SQLite instead of Postgres:
# DB_ENGINE=sqlite
# SQLITE_NAME=db.sqlite3

# ---------------------------------------------------------
# 5. Cache / queues
# ---------------------------------------------------------
REDIS_URL=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Django HTTP worker recycling (Axum owns long-lived sockets)
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_IGNORE_RESULT=True
CELERY_RESULT_EXPIRES=3600
CELERY_WORKER_MAX_TASKS_PER_CHILD=500
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_BROKER_POOL_LIMIT=5
CELERY_BROKER_HEARTBEAT=30
CELERY_TASK_TIME_LIMIT=900
CELERY_TASK_SOFT_TIME_LIMIT=840
REALTIME_OUTBOX_DELETE_BATCH_SIZE=1000
REALTIME_OUTBOX_DELETE_MAX_BATCHES=20
UPLOAD_EXPIRY_BATCH_SIZE=500
SUPPORT_WEBHOOK_DISPATCH_BATCH_SIZE=100
SUPPORT_WEBHOOK_LEASE_SECONDS=120
RUN_MIGRATIONS=1

# ---------------------------------------------------------
# 6. Security / proxy / cookies
# ---------------------------------------------------------
USE_X_FORWARDED_HOST=False
SECURE_PROXY_SSL_HEADER_ENABLED=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_HTTPONLY=False

# ---------------------------------------------------------
# 7. Email / auth
# ---------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
SUPPORT_INVITATION_EMAIL_ASYNC=False
DEFAULT_FROM_EMAIL=no-reply@example.com

AUTH_REQUIRE_EMAIL_VERIFICATION=False
EMAIL_VERIFY_TOKEN_TTL_SECONDS=86400
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
OIDC_DISCOVERY_CACHE_TTL_SECONDS=3600
GOOGLE_OIDC_CLIENT_ID=
APPLE_OIDC_CLIENT_ID=

# ---------------------------------------------------------
# 8. API rate limits / auth abuse protection
# ---------------------------------------------------------
API_USER_RATE=200/min
MESSAGE_SEND_RATE=60/min
UPLOAD_CREATE_RATE=20/min
REACTION_WRITE_RATE=120/min
REPORT_WRITE_RATE=30/min
BLOCK_WRITE_RATE=30/min
DEVICE_WRITE_RATE=30/min
MEDIA_TOKEN_RATE=120/min

# ---------------------------------------------------------
# 9. Messaging / moderation / uploads
# ---------------------------------------------------------
MAX_UPLOAD_BYTES=15728640
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,txt,csv,rtf,doc,docx,odt,xls,xlsx,ods,ppt,pptx,odp,mp3,wav,mp4,webm,m4a,aac,3gp,amr,ogg,opus
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,text/csv,application/csv,application/rtf,text/rtf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.oasis.opendocument.text,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.oasis.opendocument.spreadsheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/vnd.oasis.opendocument.presentation,application/zip,audio/mpeg,audio/mp3,audio/wav,audio/x-wav,audio/wave,audio/mp4,audio/m4a,audio/x-m4a,audio/aac,audio/3gpp,audio/amr,audio/ogg,audio/opus,audio/webm,video/mp4,video/webm,application/octet-stream
PENDING_UPLOAD_TTL_SECONDS=86400
MEDIA_TOKEN_TTL_SECONDS=300
PRESENCE_TTL_SECONDS=300
UPLOAD_SCAN_ASYNC=False
CHAT_ATTACHMENT_FORCE_DOWNLOAD=True

AUTO_HIDE_REPORT_THRESHOLD=3
MESSAGE_DUPLICATE_WINDOW_SECONDS=120
MESSAGE_DUPLICATE_THRESHOLD=3
MESSAGE_BURST_WINDOW_SECONDS=30
MESSAGE_BURST_THRESHOLD=20
MESSAGE_MAX_LINKS=5
MEDIA_SERVER_THUMBNAIL_DIMENSION=960
MEDIA_SERVER_THUMBNAIL_JPEG_QUALITY=82

# ---------------------------------------------------------
# 10. Storage
# ---------------------------------------------------------
CHAT_USE_S3_STORAGE=False
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_ADDRESSING_STYLE=auto
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_QUERYSTRING_EXPIRE=300
AWS_S3_FILE_OVERWRITE=False
AWS_S3_VERIFY=True

# Cloudflare R2. Leave empty for local storage. Filling all required values activates R2.
CHAT_USE_R2_STORAGE=False
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET_NAME=

# Encrypted system backups. Prefer a dedicated private R2 bucket.
BACKUP_R2_ENABLED=false
BACKUP_R2_BUCKET_NAME=
BACKUP_R2_PREFIX=system-backups
BACKUP_R2_RETENTION_DAYS=30
BACKUP_R2_KEEP_LATEST=7
BACKUP_LOCAL_RETENTION_DAYS=7
BACKUP_INCLUDE_MEDIA=true
BACKUP_KEEP_PLAINTEXT=false
BACKUP_KEY_FILE=secrets/backup-passphrase
BACKUP_MAX_UPLOAD_BYTES=2147483648
OPS_DISK_MAX_PERCENT=85
OPS_MIN_AVAILABLE_MEMORY_MB=256
OPS_BACKUP_MAX_AGE_HOURS=30
OPS_ALERT_WEBHOOK_URL=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ENDPOINT_URL=
CLOUDFLARE_R2_CUSTOM_DOMAIN=

# ---------------------------------------------------------
# 11. Push notifications
# ---------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=
FIREBASE_PUSH_REQUIRED=False
FCM_DRY_RUN=False
DEVICE_INACTIVE_DAYS=30

# ---------------------------------------------------------
# 12. Antivirus scanning
# ---------------------------------------------------------
CLAMAV_ENABLED=False
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=10
CLAMAV_FAIL_OPEN=False

# ---------------------------------------------------------
# 13. Calling / WebRTC
# ---------------------------------------------------------
CALL_SIGNAL_QUEUE_TTL_SECONDS=180
CALL_SIGNAL_DEDUP_TTL_SECONDS=360
CALL_OFFER_TIMEOUT_SECONDS=45
MAX_GROUP_CALL_PARTICIPANTS=8
WEBRTC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]
WEBRTC_ICE_TRANSPORT_POLICY=all
WEBRTC_ICE_CANDIDATE_POOL_SIZE=4
WEBRTC_ENABLE_SIMULCAST=1
LOW_BANDWIDTH_VIDEO_MAX_BITRATE_BPS=250000
LOW_BANDWIDTH_VIDEO_MAX_FRAMERATE=12
LOW_BANDWIDTH_VIDEO_MAX_WIDTH=320
LOW_BANDWIDTH_VIDEO_MAX_HEIGHT=240
AUDIO_FALLBACK_MAX_BITRATE_BPS=24000
CALL_AUDIO_ONLY_NETWORK_THRESHOLD=poor
CALL_RECONNECT_GRACE_SECONDS=20
CALL_QUALITY_REPORT_INTERVAL_SECONDS=5
CALL_HEARTBEAT_INTERVAL_SECONDS=10
CALL_STALE_PARTICIPANT_SECONDS=35
CALL_ICE_RESTART_BACKOFF_MS=1500
CALL_MAX_ICE_RESTARTS=4
CALL_DOMINANT_SPEAKER_HOLD_MS=2500
CALL_SPEAKER_LEVEL_THRESHOLD=35
CALL_GRID_LAYOUT_THRESHOLD=4
CALL_ALLOW_SIMULTANEOUS_SCREEN_SHARES=0
TURN_PROVIDER=cloudflare
CLOUDFLARE_TURN_KEY_ID=replace-with-cloudflare-turn-key-id
CLOUDFLARE_TURN_API_TOKEN=replace-with-cloudflare-turn-api-token
CLOUDFLARE_TURN_API_BASE_URL=https://rtc.live.cloudflare.com/v1/turn
CLOUDFLARE_TURN_REQUEST_TIMEOUT_SECONDS=5
CLOUDFLARE_TURN_FILTER_BROWSER_PORT_53=True
TURN_CREDENTIAL_TTL_SECONDS=21600
# Legacy/self-hosted TURN is retained only for local fallback tests.
TURN_URIS_JSON=
TURN_REALM=
TURN_SHARED_SECRET=
TURN_STATIC_USERNAME=
TURN_STATIC_PASSWORD=
TURN_EXTERNAL_IP=
TURN_RELAY_MIN_PORT=49160
TURN_RELAY_MAX_PORT=49200

# ---------------------------------------------------------
# 14. Logging
# ---------------------------------------------------------
REQUEST_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
CHAT_LOG_LEVEL=INFO

# Nearby discovery locations older than this are never returned
NEARBY_LOCATION_TTL_HOURS=24

# Public profile photos
PROFILE_AVATAR_MAX_BYTES=5242880
PROFILE_AVATAR_MAX_DIMENSION=1024
PROFILE_AVATAR_MAX_PIXELS=25000000

# Support Chat product (isolated from personal Messenger)
SUPPORT_CHAT_ENABLED=False
SUPPORT_CHAT_PRODUCT_CODE=support-chat
SUPPORT_AGENT_INVITE_TTL_HOURS=168
SUPPORT_WIDGET_ENABLED=False
SUPPORT_WIDGET_REQUIRE_ORIGIN=True
SUPPORT_WIDGET_SESSION_TTL_HOURS=720
SUPPORT_WIDGET_SCRIPT_URL=https://dm.crescentsphere.com/support-widget/v1/widget.js
SUPPORT_WIDGET_CONFIG_RATE=120/min
SUPPORT_WIDGET_SESSION_RATE=30/min
SUPPORT_WIDGET_RESUME_RATE=120/min
SUPPORT_WIDGET_MESSAGE_RATE=60/min
SUPPORT_MESSAGE_SEND_RATE=120/min
SUPPORT_UPLOAD_CREATE_RATE=20/min
SUPPORT_WIDGET_UPLOAD_RATE=12/min
SUPPORT_MAX_ATTACHMENTS_PER_MESSAGE=8
# 0 means MAX_UPLOAD_BYTES multiplied by the per-message attachment limit.
SUPPORT_MAX_MESSAGE_UPLOAD_BYTES=0
# Support-only outbound webhooks and private data exports.
SUPPORT_WEBHOOK_TIMEOUT_SECONDS=10
SUPPORT_WEBHOOK_MAX_ATTEMPTS=6
SUPPORT_EXPORT_MAX_ATTACHMENT_BYTES=262144000
SUPPORT_CALLS_ENABLED=False
SUPPORT_CALL_RING_TIMEOUT_SECONDS=45
SUPPORT_CALL_SIGNAL_MAX_BYTES=131072
SUPPORT_CALL_ACTION_RATE=30/min
SUPPORT_CALL_SIGNAL_RATE=240/min

VITE_SUPPORT_WS_URL=

# Realtime transport (Axum is the only production WebSocket service)
REALTIME_TRANSPORT=axum
REALTIME_OUTBOX_ENABLED=true

# Axum Redis Stream bridge
REALTIME_STREAM_ENABLED=true
REALTIME_STREAM_URL=redis://redis:6379/3
REALTIME_PRESENCE_REDIS_URL=redis://redis:6379/3
REALTIME_PRESENCE_TTL_SECONDS=90
REALTIME_PRESENCE_METADATA_TTL_SECONDS=300
REALTIME_PRESENCE_DISCONNECT_GRACE_SECONDS=12
REALTIME_STREAM_NAME=realtime:durable:v1
REALTIME_STREAM_GROUP=axum-single-v1
REALTIME_STREAM_MAXLEN=25000
REALTIME_OUTBOX_BATCH_SIZE=100
REALTIME_OUTBOX_LEASE_SECONDS=60
REALTIME_OUTBOX_RETENTION_DAYS=7
REALTIME_OUTBOX_MAX_AGE_SECONDS=120
REALTIME_OUTBOX_MAX_FAILED=25
REALTIME_STREAM_MAX_PENDING=250
REALTIME_INTERNAL_TEST_ENABLED=false
REALTIME_INTERNAL_TEST_TOKEN=
REALTIME_MAX_CONNECTIONS=500
REQUIRE_VERIFIED_CAPACITY_REPORT=False
REALTIME_MAX_CONNECTION_AGE_SECONDS=600
REALTIME_CONNECTION_REFRESH_JITTER_SECONDS=60
REALTIME_MAX_USER_CONNECTIONS=5
REALTIME_MAX_WIDGET_CONNECTIONS=2
REALTIME_MAX_DEVICE_CONNECTIONS=2
REALTIME_HIGH_QUEUE_CAPACITY=32
REALTIME_LOW_QUEUE_CAPACITY=8
REALTIME_SEND_TIMEOUT_SECONDS=5

# Axum authenticated WebSocket
REALTIME_AUTH_ENABLED=true
REALTIME_AUTH_REDIS_URL=redis://redis:6379/3
REALTIME_TOKEN_ALGORITHM=RS256
REALTIME_TOKEN_ISSUER=crescentsphere-django
REALTIME_TICKET_AUDIENCE=crescentsphere-realtime
REALTIME_GRANT_AUDIENCE=crescentsphere-realtime-grant
REALTIME_CALL_GRANT_AUDIENCE=crescentsphere-realtime-call-grant
REALTIME_TICKET_TTL_SECONDS=45
REALTIME_GRANT_TTL_SECONDS=90
REALTIME_CALL_GRANT_TTL_SECONDS=90
REALTIME_MAX_GRANTS_PER_REQUEST=50
REALTIME_REQUIRE_ORIGIN=true
REALTIME_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
REALTIME_SIGNING_PRIVATE_KEY_PATH=/run/secrets/realtime-private.pem
REALTIME_SIGNING_PUBLIC_KEY_PATH=/run/secrets/realtime-public.pem
REALTIME_TICKET_REPLAY_PREFIX=realtime:ticket-used:
REALTIME_AUTH_LEEWAY_SECONDS=5

# Controlled capacity testing
ALLOW_LOAD_TEST_DATA=false
CAPACITY_TEST_MAX_CONNECTIONS=1000
OPS_REQUIRE_CAPACITY_REPORT=false
OPS_CAPACITY_REPORT_PATH=loadtests/results/capacity-report.json
OPS_CAPACITY_REPORT_MAX_AGE_DAYS=7
# Django request/query measurement (aggregate only; no SQL text or parameters)
DJANGO_QUERY_METRICS_ENABLED=False
DJANGO_QUERY_METRICS_LOG_ALL=False
DJANGO_QUERY_METRICS_REQUEST_MS=250
DJANGO_QUERY_METRICS_DB_MS=100
DJANGO_QUERY_METRICS_MAX_QUERIES=20
DJANGO_QUERY_METRICS_EXCLUDE_PREFIXES=/health,/static,/media


# Short-lived cache for public knowledge suggestions; versioned invalidation keeps edits fresh.
SUPPORT_PUBLIC_KB_CACHE_TTL_SECONDS=60
