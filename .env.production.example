# =========================================================
# Crescentsphere Messenger — DigitalOcean + Cloudflare DNS + private R2
# Copy to .env and replace every REQUIRED_* value.
# Never commit the real .env file.
# =========================================================

# Public application identity
APP_DOMAIN=crescentsphere.com
SITE_URL=https://crescentsphere.com
FRONTEND_BASE_URL=https://crescentsphere.com
ALLOWED_HOSTS=crescentsphere.com
CORS_ALLOWED_ORIGINS=https://crescentsphere.com
CSRF_TRUSTED_ORIGINS=https://crescentsphere.com
NGINX_CONF_PATH=./nginx/snm.production.conf

# Frontend build values
VITE_API_BASE_URL=/api/v1
VITE_AUTH_BASE_URL=/api/v1
VITE_WS_BASE_URL=
VITE_SUPPORT_WS_URL=
VITE_CENTRAL_AUTH_ORIGIN=https://crescentsphere.com
VITE_SOCIAL_BASE_URL=https://crescentsphere.com
VITE_APP_NAME="Crescentsphere Messenger"

# Cloudflare DNS / origin TLS
# Create a proxied A record for APP_DOMAIN pointing to DROPLET_PUBLIC_IP.
# Put a Cloudflare Origin CA certificate at secrets/tls/origin.crt and key at
# secrets/tls/origin.key, then use SSL/TLS mode Full (strict).

# Core Django security
DEBUG=False
MESSENGER_ENVIRONMENT=production
MESSENGER_REQUIRE_SECURE_SETTINGS=True
SECRET_KEY=REQUIRED_GENERATE_INDEPENDENT_RANDOM_SECRET
APP_VERSION=v24-production
SERVICE_NAME=messenger_api
USE_X_FORWARDED_HOST=True
SECURE_PROXY_SSL_HEADER_ENABLED=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_HTTPONLY=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# PostgreSQL
DB_ENGINE=postgres
DB_NAME=messenger_api
DB_USER=messenger_user
DB_PASSWORD=REQUIRED_GENERATE_DATABASE_PASSWORD
DB_HOST=postgres
DB_PORT=5432
DATABASE_RUNTIME_ENDPOINT=pgbouncer
DATABASE_MAINTENANCE_MODE=False
DB_PGBOUNCER_HOST=pgbouncer
DB_PGBOUNCER_PORT=6432
DATABASE_CONN_MAX_AGE=60
DATABASE_CONN_HEALTH_CHECKS=True

# Redis / Celery
REDIS_URL=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=

# Django HTTP worker recycling (Axum owns long-lived sockets)
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_IGNORE_RESULT=True
CELERY_RESULT_EXPIRES=3600
CELERY_WORKER_MAX_TASKS_PER_CHILD=500
CELERY_WORKER_CONCURRENCY=1
CELERY_LOG_LEVEL=INFO
RUN_MIGRATIONS=1
UPLOAD_SCAN_ASYNC=True

# Cloudflare R2 — keep this bucket PRIVATE
CHAT_USE_R2_STORAGE=True
CHAT_USE_S3_STORAGE=True
CLOUDFLARE_R2_ACCOUNT_ID=REQUIRED_R2_ACCOUNT_ID
CLOUDFLARE_R2_BUCKET_NAME=mepia

# Encrypted system backups. Prefer a dedicated private R2 bucket.
BACKUP_R2_ENABLED=false
BACKUP_R2_BUCKET_NAME=
BACKUP_R2_PREFIX=system-backups
BACKUP_R2_RETENTION_DAYS=30
BACKUP_R2_KEEP_LATEST=7
BACKUP_LOCAL_RETENTION_DAYS=7
BACKUP_INCLUDE_MEDIA=true
BACKUP_KEEP_PLAINTEXT=false
BACKUP_KEY_FILE=secrets/backup-passphrase
BACKUP_MAX_UPLOAD_BYTES=2147483648
OPS_DISK_MAX_PERCENT=85
OPS_MIN_AVAILABLE_MEMORY_MB=256
OPS_AXUM_HIGH_QUEUE_MAX_PERCENT=75
OPS_BACKUP_MAX_AGE_HOURS=30
OPS_ALERT_WEBHOOK_URL=
CLOUDFLARE_R2_ACCESS_KEY_ID=REQUIRED_R2_ACCESS_KEY_ID
CLOUDFLARE_R2_SECRET_ACCESS_KEY=REQUIRED_R2_SECRET_ACCESS_KEY
# Optional for EU/FedRAMP jurisdiction endpoints; otherwise leave blank.
CLOUDFLARE_R2_ENDPOINT_URL=
# Do not use an R2 custom domain for private chat files/presigned URLs.
CLOUDFLARE_R2_CUSTOM_DOMAIN=
AWS_S3_ADDRESSING_STYLE=path
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_QUERYSTRING_EXPIRE=300
AWS_S3_FILE_OVERWRITE=False
AWS_S3_VERIFY=True
MEDIA_TOKEN_TTL_SECONDS=300
MEDIA_TOKEN_SHARED_SECRET=replace-with-at-least-32-random-characters
MEDIA_TOKEN_ISSUER=crescentsphere-media
MEDIA_TOKEN_AUDIENCE=crescentsphere-private-media

# Upload policy
MAX_UPLOAD_BYTES=15728640
MEDIA_SERVER_THUMBNAIL_DIMENSION=960
MEDIA_SERVER_THUMBNAIL_JPEG_QUALITY=82

# Separate Rust media worker. Antivirus remains in Django/ClamAV; this worker
# handles metadata probing, thumbnails and compact audio waveforms after approval.
MEDIA_PROCESSING_BACKEND=rust
MEDIA_WORKER_RUST_LOG=crescentsphere_media_worker=info
MEDIA_WORKER_NAME=media-worker-01
MEDIA_WORKER_CONCURRENCY=1
MEDIA_WORKER_POLL_INTERVAL_MS=750
MEDIA_WORKER_LEASE_SECONDS=300
MEDIA_WORKER_MAX_ATTEMPTS=4
MEDIA_WORKER_MAX_SOURCE_BYTES=262144000
MEDIA_WORKER_MAX_FRAME_DIMENSION=32768
MEDIA_WORKER_MAX_FRAME_PIXELS=80000000
MEDIA_WORKER_PROBE_TIMEOUT_SECONDS=15
MEDIA_WORKER_PROCESS_TIMEOUT_SECONDS=90
MEDIA_WORKER_WAVEFORM_POINTS=48
MEDIA_WORKER_WAVEFORM_MAX_SECONDS=600
MEDIA_WORKER_FFMPEG_THREADS=1
MEDIA_WORKER_STORAGE_PREFIX=chat-private
MEDIA_WORKER_DJANGO_FALLBACK_ENABLED=False
MEDIA_WORKER_DJANGO_FALLBACK_AFTER_ATTEMPTS=4
MEDIA_WORKER_ENQUEUE_RECOVERY_BATCH_SIZE=250
MEDIA_VIDEO_THUMBNAIL_OFFSET_SECONDS=0.25
PENDING_UPLOAD_TTL_SECONDS=86400
CHAT_ATTACHMENT_FORCE_DOWNLOAD=True

# VPS public address and Cloudflare Realtime TURN
DROPLET_PUBLIC_IP=159.203.29.80
TURN_PROVIDER=cloudflare
CLOUDFLARE_TURN_KEY_ID=REQUIRED_CLOUDFLARE_TURN_KEY_ID
CLOUDFLARE_TURN_API_TOKEN=REQUIRED_CLOUDFLARE_TURN_API_TOKEN
CLOUDFLARE_TURN_API_BASE_URL=https://rtc.live.cloudflare.com/v1/turn
CLOUDFLARE_TURN_REQUEST_TIMEOUT_SECONDS=5
CLOUDFLARE_TURN_FILTER_BROWSER_PORT_53=True
TURN_CREDENTIAL_TTL_SECONDS=21600
PRESENCE_TTL_SECONDS=300
WEBRTC_ICE_SERVERS_JSON='[{"urls":["stun:stun.cloudflare.com:3478"]}]'
WEBRTC_ICE_TRANSPORT_POLICY=all
WEBRTC_ICE_CANDIDATE_POOL_SIZE=4

# Standalone authentication; no central auth, payments, or admin services.
CENTRAL_AUTH_ENABLED=False
CENTRAL_PAYMENTS_ENABLED=False
CENTRAL_ADMIN_ENABLED=False
CENTRAL_ACCESS_MODE=observe
AUTH_PAYMENT_BASE_URL=https://crescentsphere.com
CENTRAL_AUTH_PUBLIC_BASE_URL=https://crescentsphere.com
ADMIN_CONTROL_BASE_URL=https://crescentsphere.com
CENTRAL_ADMIN_PUBLIC_BASE_URL=https://crescentsphere.com
CENTRAL_AUTH_CALLBACK_URL=https://crescentsphere.com/auth/callback/
CENTRAL_LOGIN_URL=https://crescentsphere.com/login/
CENTRAL_SIGNUP_URL=https://crescentsphere.com/register/
CENTRAL_ACCOUNT_URL=https://crescentsphere.com/settings/
CENTRAL_PASSWORD_RESET_URL=https://crescentsphere.com/forgot-password/
CENTRAL_EMAIL_VERIFICATION_URL=https://crescentsphere.com/auth/verify-email/
CENTRAL_LOGOUT_URL=https://crescentsphere.com/
AUTH_PAYMENT_ADMIN_SERVICE_KEY=
AUTH_PAYMENT_ADMIN_SIGNING_SECRET=
AUTH_PAYMENT_JWT_ALGORITHM=HS256
AUTH_PAYMENT_JWT_SIGNING_KEY=REQUIRED_GENERATE_INDEPENDENT_JWT_SIGNING_SECRET_AT_LEAST_64_CHARACTERS
AUTH_PAYMENT_JWT_PUBLIC_KEY=
AUTH_PAYMENT_JWT_ISSUER=https://crescentsphere.com
AUTH_PAYMENT_JWT_AUDIENCE=messenger-api
# Axum inherits these AUTH_PAYMENT_JWT_* values for access-token verification.

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=REQUIRED_RESEND_API_KEY
# Support invitations use the same EMAIL_* transport as authentication.
SUPPORT_INVITATION_EMAIL_ASYNC=False
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@crescentsphere.com
AUTH_REQUIRE_EMAIL_VERIFICATION=True
EMAIL_VERIFY_OTP_TTL_SECONDS=600
EMAIL_VERIFY_OTP_MAX_ATTEMPTS=5

# Firebase push is optional. Set FIREBASE_PUSH_REQUIRED=True only after a
# service account is mounted and production delivery is intentionally enabled.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=
FIREBASE_PUSH_REQUIRED=False
FCM_DRY_RUN=True
DEVICE_INACTIVE_DAYS=30

# Antivirus (recommended for public uploads)
CLAMAV_ENABLED=False
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=15
CLAMAV_FAIL_OPEN=False

# Logging
REQUEST_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
CHAT_LOG_LEVEL=INFO

# Nearby discovery locations older than this are never returned
NEARBY_LOCATION_TTL_HOURS=24

# Public profile photos
PROFILE_AVATAR_MAX_BYTES=5242880
PROFILE_AVATAR_MAX_DIMENSION=1024
PROFILE_AVATAR_MAX_PIXELS=25000000

# Support Chat product. Keep disabled until migrations and account entitlements are ready.
SUPPORT_CHAT_ENABLED=False
SUPPORT_CHAT_PRODUCT_CODE=support-chat
SUPPORT_AGENT_INVITE_TTL_HOURS=168
SUPPORT_WIDGET_ENABLED=False
SUPPORT_WIDGET_REQUIRE_ORIGIN=True
SUPPORT_WIDGET_SESSION_TTL_HOURS=720
SUPPORT_WIDGET_SCRIPT_URL=https://dm.crescentsphere.com/support-widget/v1/widget.js
SUPPORT_WIDGET_CONFIG_RATE=120/min
SUPPORT_WIDGET_SESSION_RATE=30/min
SUPPORT_WIDGET_RESUME_RATE=120/min
SUPPORT_WIDGET_MESSAGE_RATE=60/min
SUPPORT_UPLOAD_CREATE_RATE=20/min
SUPPORT_WIDGET_UPLOAD_RATE=12/min
SUPPORT_MAX_ATTACHMENTS_PER_MESSAGE=8
# 0 means MAX_UPLOAD_BYTES multiplied by the per-message attachment limit.
SUPPORT_MAX_MESSAGE_UPLOAD_BYTES=0
# Support-only outbound webhooks and private data exports.
SUPPORT_WEBHOOK_TIMEOUT_SECONDS=10
SUPPORT_WEBHOOK_MAX_ATTEMPTS=6
SUPPORT_EXPORT_MAX_ATTACHMENT_BYTES=262144000
SUPPORT_CALLS_ENABLED=False
SUPPORT_CALL_RING_TIMEOUT_SECONDS=45
SUPPORT_CALL_SIGNAL_MAX_BYTES=131072
SUPPORT_WIDGET_MESSAGE_RATE_PER_MINUTE=30
SUPPORT_SIGNAL_RATE_PER_SECOND=30
SUPPORT_CALL_ACTION_RATE=30/min
SUPPORT_CALL_SIGNAL_RATE=240/min

# Realtime transport (Axum is the only production WebSocket service)
REALTIME_TRANSPORT=axum
REALTIME_MIGRATION_MODE=nats
REALTIME_DURABLE_BACKEND=nats

# NATS foundation settings. Select the active transport through the realtime backend variables.
NATS_PROBE_ENABLED=false
NATS_CONNECT_TIMEOUT_SECONDS=3
NATS_CHAT_STREAM=CHAT_EVENTS
NATS_NODE_ID=axum-01
NATS_DURABLE_CONSUMER=realtime-axum-v1
NATS_DURABLE_SUBJECT_FILTER=event.chat.>
NATS_EPHEMERAL_SUBJECT=rt.ephemeral.v1
NATS_ACK_WAIT_SECONDS=30
NATS_MAX_DELIVER=5
NATS_MAX_ACK_PENDING=128
REALTIME_EVENT_DEDUPE_CAPACITY=10000
NATS_OWNERSHIP_SUBJECT=rt.ownership.v1
NATS_DELIVERY_SUBJECT_PREFIX=rt.deliver
REALTIME_OWNERSHIP_ANNOUNCE_SECONDS=5
REALTIME_OWNERSHIP_LEASE_TTL_SECONDS=20
REALTIME_CONNECTION_OWNERSHIP_BACKEND=local
NATS_APP_USER=django
NATS_APP_PASSWORD=change-me-nats-app
NATS_REALTIME_USER=realtime
NATS_REALTIME_PASSWORD=change-me-nats-realtime
NATS_APP_URL=nats://django:change-me-nats-app@nats:4222
NATS_REALTIME_URL=nats://realtime:change-me-nats-realtime@nats:4222
REALTIME_EPHEMERAL_BACKEND=nats
# Single-node production presence stays inside Axum; Core NATS carries ephemeral events.
REALTIME_PRESENCE_BACKEND=local
REALTIME_OUTBOX_ENABLED=true
REALTIME_OUTBOX_PUBLISHER=axum
REALTIME_OUTBOX_PUBLISH_TIMEOUT_MS=1500
REALTIME_OUTBOX_MARK_ATTEMPTS=3

# Redis remains for one-time realtime ticket replay, Celery broker, and Django cache
REALTIME_PRESENCE_REDIS_URL=redis://redis:6379/3
REALTIME_PRESENCE_TTL_SECONDS=90
REALTIME_PRESENCE_METADATA_TTL_SECONDS=300
REALTIME_PRESENCE_DISCONNECT_GRACE_SECONDS=12
REALTIME_OUTBOX_BATCH_SIZE=100
REALTIME_OUTBOX_LEASE_SECONDS=60
REALTIME_OUTBOX_WAKE_KEY=realtime:outbox:wake
REALTIME_OUTBOX_WAKE_TTL_SECONDS=10
REALTIME_OUTBOX_RECOVERY_INTERVAL_SECONDS=15
REALTIME_OUTBOX_RETENTION_DAYS=7
REALTIME_OUTBOX_MAX_AGE_SECONDS=120
REALTIME_OUTBOX_MAX_FAILED=25
REALTIME_INTERNAL_TEST_ENABLED=false
REALTIME_INTERNAL_TEST_TOKEN=
REALTIME_MAX_CONNECTIONS=500
REQUIRE_VERIFIED_CAPACITY_REPORT=False
REALTIME_MAX_CONNECTION_AGE_SECONDS=3600
REALTIME_CONNECTION_REFRESH_JITTER_SECONDS=300
REALTIME_MAX_USER_CONNECTIONS=5
REALTIME_MAX_WIDGET_CONNECTIONS=2
REALTIME_MAX_DEVICE_CONNECTIONS=2
REALTIME_HIGH_QUEUE_CAPACITY=32
REALTIME_LOW_QUEUE_CAPACITY=8
REALTIME_READ_BUFFER_SIZE=4096
REALTIME_WRITE_BUFFER_SIZE=4096
REALTIME_MAX_WRITE_BUFFER_SIZE=131072
REALTIME_HEARTBEAT_SECONDS=30
REALTIME_CLIENT_TIMEOUT_SECONDS=90
REALTIME_SEND_TIMEOUT_SECONDS=5

# Axum authenticated WebSocket. Generate the key files with
# ./scripts/generate-realtime-keys.sh.
REALTIME_AUTH_ENABLED=true
REALTIME_AUTH_REDIS_URL=redis://redis:6379/3
REALTIME_TOKEN_ALGORITHM=RS256
REALTIME_TOKEN_ISSUER=crescentsphere-django
REALTIME_TICKET_AUDIENCE=crescentsphere-realtime
REALTIME_GRANT_AUDIENCE=crescentsphere-realtime-grant
REALTIME_CALL_GRANT_AUDIENCE=crescentsphere-realtime-call-grant
REALTIME_TICKET_TTL_SECONDS=45
REALTIME_GRANT_TTL_SECONDS=90
REALTIME_CALL_GRANT_TTL_SECONDS=90
REALTIME_MAX_GRANTS_PER_REQUEST=50
REALTIME_REQUIRE_ORIGIN=true
REALTIME_ALLOWED_ORIGINS=https://dm.example.com
REALTIME_SIGNING_PRIVATE_KEY_PATH=/run/secrets/realtime-private.pem
REALTIME_SIGNING_PUBLIC_KEY_PATH=/run/secrets/realtime-public.pem
REALTIME_TICKET_REPLAY_PREFIX=realtime:ticket-used:
REALTIME_AUTH_LEEWAY_SECONDS=5

# Controlled capacity testing. Keep false except while creating or cleaning
# temporary load-test users from scripts/prepare-load-test-data.sh.
ALLOW_LOAD_TEST_DATA=false
CAPACITY_TEST_MAX_CONNECTIONS=1000
OPS_REQUIRE_CAPACITY_REPORT=false
OPS_CAPACITY_REPORT_PATH=loadtests/results/capacity-report.json
OPS_CAPACITY_REPORT_MAX_AGE_DAYS=7
# Django request/query measurement (aggregate only; no SQL text or parameters)
DJANGO_QUERY_METRICS_ENABLED=False
DJANGO_QUERY_METRICS_LOG_ALL=False
DJANGO_QUERY_METRICS_REQUEST_MS=250
DJANGO_QUERY_METRICS_DB_MS=100
DJANGO_QUERY_METRICS_MAX_QUERIES=20
DJANGO_QUERY_METRICS_EXCLUDE_PREFIXES=/health,/static,/media


# Short-lived cache for public knowledge suggestions; versioned invalidation keeps edits fresh.
SUPPORT_PUBLIC_KB_CACHE_TTL_SECONDS=60

# Final production data plane. Django remains the control plane and emergency rollback.
AXUM_DATA_PLANE_REQUIRED=True
CHAT_READ_BACKEND=sqlx
CHAT_COMMAND_BACKEND=axum
CHAT_INTERACTION_BACKEND=axum
CHAT_MESSAGE_MUTATION_BACKEND=axum
CHAT_CALL_RUNTIME_BACKEND=axum
CHAT_ATTACHMENT_BACKEND=axum
CHAT_CONVERSATION_COMMAND_BACKEND=axum
SUPPORT_DATA_BACKEND=axum
CHAT_DATA_PLANE_JOB_BATCH_SIZE=150
CHAT_DATA_PLANE_JOB_LEASE_SECONDS=120
CHAT_DATA_PLANE_JOB_RETENTION_DAYS=7
SUPPORT_DATA_PLANE_JOB_BATCH_SIZE=100
SUPPORT_DATA_PLANE_JOB_LEASE_SECONDS=120
SUPPORT_DATA_PLANE_JOB_RETENTION_DAYS=7
SUPPORT_SIGNAL_QUEUE_CAPACITY=256
SUPPORT_SIGNAL_QUEUE_TTL_SECONDS=180
VITE_CHAT_COMMAND_BACKEND=axum
VITE_CHAT_INTERACTION_BACKEND=axum
VITE_CHAT_MESSAGE_MUTATION_BACKEND=axum
VITE_CHAT_CALL_RUNTIME_BACKEND=axum
VITE_CHAT_ATTACHMENT_BACKEND=axum
VITE_CHAT_CONVERSATION_COMMAND_BACKEND=axum
VITE_SUPPORT_DATA_BACKEND=axum
VITE_CHAT_READ_BACKEND=sqlx
SQLX_MIN_CONNECTIONS=1
SQLX_MAX_CONNECTIONS=4
SQLX_ACQUIRE_TIMEOUT_MS=1500
SQLX_IDLE_TIMEOUT_SECONDS=60
SQLX_MAX_LIFETIME_SECONDS=900
REALTIME_HTTP_READ_CONCURRENCY=24
REALTIME_HTTP_WRITE_CONCURRENCY=12
REALTIME_HTTP_REQUEST_TIMEOUT_MS=10000
REALTIME_HTTP_MAX_BODY_BYTES=1048576

DJANGO_SERVER=granian
DJANGO_BIND_HOST=0.0.0.0
DJANGO_PORT=8000
GRANIAN_WORKERS=1
GUNICORN_WORKERS=2
GUNICORN_THREADS=2

NATS_DURABLE_SUBJECT_PREFIX=event.chat
NATS_DURABLE_MAX_AGE_SECONDS=86400
NATS_DURABLE_MAX_BYTES=536870912

CALL_SIGNAL_QUEUE_CAPACITY=256
CALL_SIGNAL_QUEUE_TTL_SECONDS=180
CALL_RECONNECT_GRACE_SECONDS=20
CALL_STALE_PARTICIPANT_SECONDS=35
CALL_SPEAKER_LEVEL_THRESHOLD=35
CALL_GRID_LAYOUT_THRESHOLD=4
