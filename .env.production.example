# =========================================================
# Crescentsphere Messenger — DigitalOcean + Cloudflare DNS + private R2
# Copy to .env and replace every REQUIRED_* value.
# Never commit the real .env file.
# =========================================================

# Public application identity
APP_DOMAIN=crescentsphere.com
SITE_URL=https://crescentsphere.com
FRONTEND_BASE_URL=https://crescentsphere.com
ALLOWED_HOSTS=crescentsphere.com
CORS_ALLOWED_ORIGINS=https://crescentsphere.com
CSRF_TRUSTED_ORIGINS=https://crescentsphere.com
NGINX_CONF_PATH=./nginx/snm.production.conf

# Frontend build values
VITE_API_BASE_URL=/api/v1
VITE_AUTH_BASE_URL=/api/v1
VITE_WS_BASE_URL=
VITE_SUPPORT_WS_URL=
VITE_CENTRAL_AUTH_ORIGIN=https://crescentsphere.com
VITE_SOCIAL_BASE_URL=https://crescentsphere.com
VITE_APP_NAME="Crescentsphere Messenger"

# Cloudflare DNS / origin TLS
# Create a proxied A record for APP_DOMAIN pointing to DROPLET_PUBLIC_IP.
# Put a Cloudflare Origin CA certificate at secrets/tls/origin.crt and key at
# secrets/tls/origin.key, then use SSL/TLS mode Full (strict).

# Core Django security
DEBUG=False
MESSENGER_ENVIRONMENT=production
MESSENGER_REQUIRE_SECURE_SETTINGS=True
SECRET_KEY=REQUIRED_GENERATE_INDEPENDENT_RANDOM_SECRET
APP_VERSION=v24-production
SERVICE_NAME=messenger_api
USE_X_FORWARDED_HOST=True
SECURE_PROXY_SSL_HEADER_ENABLED=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_HTTPONLY=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# PostgreSQL
DB_ENGINE=postgres
DB_NAME=messenger_api
DB_USER=messenger_user
DB_PASSWORD=REQUIRED_GENERATE_DATABASE_PASSWORD
DB_HOST=postgres
DB_PORT=5432
DATABASE_CONN_MAX_AGE=60

# Redis / Channels / Celery
REDIS_URL=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=False
CELERY_WORKER_CONCURRENCY=2
CELERY_LOG_LEVEL=INFO
RUN_MIGRATIONS=1
UPLOAD_SCAN_ASYNC=True

# Cloudflare R2 — keep this bucket PRIVATE
CHAT_USE_R2_STORAGE=True
CHAT_USE_S3_STORAGE=True
CLOUDFLARE_R2_ACCOUNT_ID=REQUIRED_R2_ACCOUNT_ID
CLOUDFLARE_R2_BUCKET_NAME=mepia
CLOUDFLARE_R2_ACCESS_KEY_ID=REQUIRED_R2_ACCESS_KEY_ID
CLOUDFLARE_R2_SECRET_ACCESS_KEY=REQUIRED_R2_SECRET_ACCESS_KEY
# Optional for EU/FedRAMP jurisdiction endpoints; otherwise leave blank.
CLOUDFLARE_R2_ENDPOINT_URL=
# Do not use an R2 custom domain for private chat files/presigned URLs.
CLOUDFLARE_R2_CUSTOM_DOMAIN=
AWS_S3_ADDRESSING_STYLE=path
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_QUERYSTRING_EXPIRE=300
AWS_S3_FILE_OVERWRITE=False
AWS_S3_VERIFY=True
MEDIA_TOKEN_TTL_SECONDS=300

# Upload policy
MAX_UPLOAD_BYTES=15728640
MEDIA_SERVER_THUMBNAIL_DIMENSION=960
MEDIA_SERVER_THUMBNAIL_JPEG_QUALITY=82
PENDING_UPLOAD_TTL_SECONDS=86400
CHAT_ATTACHMENT_FORCE_DOWNLOAD=True

# DigitalOcean public address and TURN
DROPLET_PUBLIC_IP=159.203.29.80
TURN_REALM=turn.crescentsphere.com
TURN_SHARED_SECRET=REQUIRED_GENERATE_INDEPENDENT_TURN_SECRET
TURN_URIS_JSON='["turn:turn.crescentsphere.com:3478?transport=udp","turn:turn.crescentsphere.com:3478?transport=tcp"]'
PRESENCE_TTL_SECONDS=300
WEBRTC_ICE_SERVERS_JSON='[{"urls":["stun:stun.cloudflare.com:3478"]}]'
WEBRTC_ICE_TRANSPORT_POLICY=all
WEBRTC_ICE_CANDIDATE_POOL_SIZE=4
TURN_EXTERNAL_IP=159.203.29.80
TURN_RELAY_MIN_PORT=49160
TURN_RELAY_MAX_PORT=49200
TURN_TOTAL_QUOTA=1200
TURN_USER_QUOTA=12

# Standalone authentication; no central auth, payments, or admin services.
CENTRAL_AUTH_ENABLED=False
CENTRAL_PAYMENTS_ENABLED=False
CENTRAL_ADMIN_ENABLED=False
CENTRAL_ACCESS_MODE=observe
AUTH_PAYMENT_BASE_URL=https://crescentsphere.com
CENTRAL_AUTH_PUBLIC_BASE_URL=https://crescentsphere.com
ADMIN_CONTROL_BASE_URL=https://crescentsphere.com
CENTRAL_ADMIN_PUBLIC_BASE_URL=https://crescentsphere.com
CENTRAL_AUTH_CALLBACK_URL=https://crescentsphere.com/auth/callback/
CENTRAL_LOGIN_URL=https://crescentsphere.com/login/
CENTRAL_SIGNUP_URL=https://crescentsphere.com/register/
CENTRAL_ACCOUNT_URL=https://crescentsphere.com/settings/
CENTRAL_PASSWORD_RESET_URL=https://crescentsphere.com/forgot-password/
CENTRAL_EMAIL_VERIFICATION_URL=https://crescentsphere.com/auth/verify-email/
CENTRAL_LOGOUT_URL=https://crescentsphere.com/
AUTH_PAYMENT_ADMIN_SERVICE_KEY=
AUTH_PAYMENT_ADMIN_SIGNING_SECRET=
AUTH_PAYMENT_JWT_ALGORITHM=HS256
AUTH_PAYMENT_JWT_SIGNING_KEY=REQUIRED_GENERATE_INDEPENDENT_JWT_SIGNING_SECRET_AT_LEAST_64_CHARACTERS
AUTH_PAYMENT_JWT_PUBLIC_KEY=
AUTH_PAYMENT_JWT_ISSUER=https://crescentsphere.com
AUTH_PAYMENT_JWT_AUDIENCE=messenger-api

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=REQUIRED_RESEND_API_KEY
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@crescentsphere.com
AUTH_REQUIRE_EMAIL_VERIFICATION=True
EMAIL_VERIFY_OTP_TTL_SECONDS=600
EMAIL_VERIFY_OTP_MAX_ATTEMPTS=5

# Firebase push is disabled until a service account is configured.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=
FCM_DRY_RUN=True
DEVICE_INACTIVE_DAYS=30

# Antivirus (recommended for public uploads)
CLAMAV_ENABLED=False
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=15
CLAMAV_FAIL_OPEN=False

# Logging
REQUEST_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
CHAT_LOG_LEVEL=INFO

# Nearby discovery locations older than this are never returned
NEARBY_LOCATION_TTL_HOURS=24

# Public profile photos
PROFILE_AVATAR_MAX_BYTES=5242880
PROFILE_AVATAR_MAX_DIMENSION=1024
PROFILE_AVATAR_MAX_PIXELS=25000000

# Support Chat product. Keep disabled until migrations and account entitlements are ready.
SUPPORT_CHAT_ENABLED=False
SUPPORT_CHAT_PRODUCT_CODE=support-chat
SUPPORT_AGENT_INVITE_TTL_HOURS=168
SUPPORT_WIDGET_ENABLED=False
SUPPORT_WIDGET_REQUIRE_ORIGIN=True
SUPPORT_WIDGET_SESSION_TTL_HOURS=720
SUPPORT_WIDGET_SCRIPT_URL=https://dm.crescentsphere.com/support-widget/v1/widget.js
SUPPORT_WIDGET_CONFIG_RATE=120/min
SUPPORT_WIDGET_SESSION_RATE=30/min
SUPPORT_WIDGET_RESUME_RATE=120/min
SUPPORT_WIDGET_MESSAGE_RATE=60/min
SUPPORT_UPLOAD_CREATE_RATE=20/min
SUPPORT_WIDGET_UPLOAD_RATE=12/min
SUPPORT_MAX_ATTACHMENTS_PER_MESSAGE=8
# 0 means MAX_UPLOAD_BYTES multiplied by the per-message attachment limit.
SUPPORT_MAX_MESSAGE_UPLOAD_BYTES=0
# Support-only outbound webhooks and private data exports.
SUPPORT_WEBHOOK_TIMEOUT_SECONDS=10
SUPPORT_WEBHOOK_MAX_ATTEMPTS=6
SUPPORT_EXPORT_MAX_ATTACHMENT_BYTES=262144000
SUPPORT_CALLS_ENABLED=False
SUPPORT_CALL_RING_TIMEOUT_SECONDS=45
SUPPORT_CALL_SIGNAL_MAX_BYTES=131072
SUPPORT_CALL_ACTION_RATE=30/min
SUPPORT_CALL_SIGNAL_RATE=240/min
