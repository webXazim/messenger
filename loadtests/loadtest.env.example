# Run this file only on the external load generator.
LOADTEST_BASE_URL=https://dm.example.com
LOADTEST_WS_URL=wss://dm.example.com/ws
LOADTEST_ORIGIN=https://dm.example.com
LOADTEST_DATA=/data/users.json
K6_IMAGE=grafana/k6:latest

# Final mixed production profile
MIXED_SOCKET_VUS=500
MIXED_READ_RATE=20
MIXED_WRITE_RATE=5
MIXED_WARMUP_DURATION=60s
MIXED_HOLD_DURATION=300s
MIXED_RAMP_DOWN_DURATION=30s
MIXED_SOCKET_LIFETIME_MS=390000
MIXED_READ_PREALLOCATED_VUS=40
MIXED_READ_MAX_VUS=120
MIXED_WRITE_PREALLOCATED_VUS=25
MIXED_WRITE_MAX_VUS=80
